<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvBookingDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1E293B"
            android:textSize="14sp"
            android:background="#F1F5F9"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/edtCustomerName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vui lòng nhập tên!"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/edtPhoneNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Vui lòng nhập SĐT!"
            android:inputType="phone"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/layoutPaymentQR"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="12dp"
            android:background="#F8FAFC"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💳 QUÉT MÃ ĐỂ THANH TOÁN ONLINE"
                android:textStyle="bold"
                android:textColor="#1E293B"
                android:textSize="15sp"/>

            <ImageView
                android:id="@+id/imgVietQR"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="8dp"
                android:scaleType="fitCenter"/>

            <TextView
                android:id="@+id/tvQRInstruction"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Giữ nguyên nội dung chuyển khoản khi quét mã"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:padding="8dp"
            android:background="#F0FDF4"> <Button
            android:id="@+id/btnSelectBill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📷 Tải ảnh hóa đơn / Bill chuyển khoản"
            android:backgroundTint="#16A34A"/>

            <ImageView
                android:id="@+id/imgBillPreview"
                android:layout_width="120dp"
                android:layout_height="160dp"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:scaleType="centerCrop"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="XÁC NHẬN ĐẶT SÂN &amp; THANH TOÁN"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>