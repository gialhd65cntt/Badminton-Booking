<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#E8F5E9"
    tools:context=".CourtListActivity">

    <RelativeLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#15803D"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Trạng thái sân"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <GridLayout
        android:id="@+id/layoutFilters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#15803D"
        android:columnCount="2"
        android:paddingHorizontal="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar">
        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_filter_item"
            android:gravity="center"
            android:text="Tất cả 🕒"
            android:textColor="#FFFFFF" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_filter_item"
            android:gravity="center"
            android:text="Khánh Việt 📍"
            android:textColor="#FFFFFF" />
        <TextView
            android:id="@+id/tvFilterCellWidth"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_filter_item"
            android:gravity="center"
            android:text="30 ↕"
            android:textColor="#FFFFFF" />
        <TextView
            android:id="@+id/tvFilterDate"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            android:background="@drawable/bg_filter_item"
            android:gravity="center"
            android:text="23/05/2026 📅"
            android:textColor="#FFFFFF" />
    </GridLayout>

    <LinearLayout
        android:id="@+id/layoutNotes"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#15803D"
        android:orientation="horizontal"
        android:paddingBottom="8dp"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/layoutFilters">
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#FFFFFF" android:layout_marginHorizontal="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trống" android:textColor="#FFFFFF" android:textSize="11sp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#38BDF8" android:layout_marginHorizontal="4dp" android:layout_marginStart="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cố định" android:textColor="#FFFFFF" android:textSize="11sp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#10B981" android:layout_marginHorizontal="4dp" android:layout_marginStart="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Lịch ngày" android:textColor="#FFFFFF" android:textSize="11sp"/>
        <View android:layout_width="12dp" android:layout_height="12dp" android:background="#F59E0B" android:layout_marginHorizontal="4dp" android:layout_marginStart="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Linh hoạt" android:textColor="#FFFFFF" android:textSize="11sp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/layoutNotes"
        app:layout_constraintBottom_toTopOf="@id/layoutBottomActions">

        <LinearLayout
            android:id="@+id/layoutHeaderTimeline"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#D1FAE5"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tvDateLabel"
                android:layout_width="70dp"
                android:layout_height="match_parent"
                android:background="#E2E8F0"
                android:gravity="center"
                android:text="Sân / Giờ"
                android:textColor="#1E293B"
                android:textSize="11sp"
                android:textStyle="bold" />

            <HorizontalScrollView
                android:id="@+id/headerScroll"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">
                <LinearLayout
                    android:id="@+id/layoutTimeLabels"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:orientation="horizontal" />
            </HorizontalScrollView>
            <LinearLayout
                android:id="@+id/layoutQuickBookingBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="#FFFFFF"
                android:elevation="16dp"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:visibility="gone"
                android:layout_alignParentBottom="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvQuickBookingSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang chọn: Sân 1 (4 ca)"
                        android:textColor="#1E293B"
                        android:textStyle="bold"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tvQuickBookingPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tổng tiền: 130.000đ"
                        android:textColor="#059669"
                        android:textStyle="bold"
                        android:textSize="17sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnQuickBookingSubmit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đặt lịch"
                    android:backgroundTint="#059669"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:paddingHorizontal="24dp" />
            </LinearLayout>

        </LinearLayout>



        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvCourtTimeline"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:cacheColorHint="@android:color/transparent"
            android:scrollbars="vertical"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/layoutBottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center"
        android:background="#E8F5E9"
        app:layout_constraintBottom_toBottomOf="parent">
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔄 Chọn lại"
            android:backgroundTint="#10B981"
            android:layout_marginEnd="8dp"/>
        <Button
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Đặt lịch"
            android:backgroundTint="#9CA3AF" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>